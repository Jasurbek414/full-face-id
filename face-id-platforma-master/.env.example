# ═══════════════════════════════════════════════════════════
# WorkTrack Pro — Environment Variables Example
# .env.example faylini ko'chirib .env nomini bering:
#   cp .env.example .env
# So'ng barcha qiymatlarni o'z serveringizga moslang.
# ═══════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-very-secret-key-change-this-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ── JWT RSA kalitlari (gen_keys.py bilan yarating) ────────
JWT_PRIVATE_KEY=your-rsa-private-key-string
JWT_PUBLIC_KEY=your-rsa-public-key-string

# Superadmin JWT (HS256)
SA_JWT_SECRET=sa-superadmin-secret-key-change-this

# ── PostgreSQL ────────────────────────────────────────────
# Local ishga tushirish uchun:
DB_NAME=worktrackpro
DB_USER=worktrack
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=5432

# Docker ichida:
DATABASE_URL=postgres://worktrack:worktrack_pass@db:5432/worktrack_db
POSTGRES_USER=worktrack
POSTGRES_PASSWORD=worktrack_pass
POSTGRES_DB=worktrack_db

# ── Redis ─────────────────────────────────────────────────
# Local:
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_HOST=127.0.0.1
# Docker ichida:
# REDIS_URL=redis://redis:6379/0
# REDIS_HOST=redis
REDIS_PORT=6379

# ── Email (Gmail SMTP) ────────────────────────────────────
# Development: emaillar terminalni chiqadi
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Production:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
# Gmail App Password: myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=WorkTrack Pro <noreply@gmail.com>
EMAIL_OTP_EXPIRE_MINUTES=10

# ── Frontend (Docker build uchun) ─────────────────────────
VITE_API_URL=http://localhost/api/v1
VITE_WS_URL=ws://localhost/ws
