# ── Django Core ─────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-this-to-a-secure-random-50-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database — leave commented to use SQLite in development ──────────────────
# DB_NAME=worktrackpro
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# For SuperAdmin panel (HS256)
SA_JWT_SECRET=sa-secret-change-me-to-random-string

# For main API (RS256) — generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste content below (use \n for newlines) OR place private.pem / public.pem in backend/ folder
# JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# ── Email (Gmail SMTP example) ───────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-app@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=WorkTrack Pro <your-app@gmail.com>
EMAIL_OTP_EXPIRE_MINUTES=10

# ── MinIO / S3 storage (optional in development) ─────────────────────────────
# Uncomment to enable MinIO; leave commented to use local filesystem storage
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=worktrackpro
# MINIO_ENDPOINT=http://localhost:9000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Frontend URL (for production)
# FRONTEND_URL=https://your-domain.com
